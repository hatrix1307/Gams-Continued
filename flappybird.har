            "mimeType": "text/css",
            "text": ":root{color-scheme:dark}html,body{margin:0;height:100%;overflow:hidden}body{background:#000;color:#fff;font-family:system-ui,sans-serif}canvas{background:#111}#root{display:flex;align-items:center;justify-content:center;height:100%}.loading-overlay{position:fixed;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;background:#4ec0ca;color:#fff;z-index:200;opacity:1;transition:opacity .3s ease}.loading-overlay[data-loaded=true]{opacity:0;pointer-events:none}.loading-overlay__logo{width:min(78vw,460px);height:auto}.loading-overlay__spinner{margin-top:12vh;width:48px;height:48px;border:5px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite}.leaderboard-panel__loading{display:flex;flex-direction:column;align-items:center;gap:10px}.leaderboard-panel__spinner{width:28px;height:28px;border:4px solid rgba(179,131,93,.35);border-top-color:#b3835d;border-radius:50%;animation:spin .8s linear infinite}.loading-overlay__label{font-size:18px;letter-spacing:.05em}@keyframes spin{to{transform:rotate(360deg)}}.navbar{position:fixed;bottom:0;left:0;right:0;height:48px;box-sizing:border-box;display:flex;align-items:center;gap:8px;padding:0 12px;background:#2c2f33;box-shadow:0 -1px 4px #0006;z-index:100;font-family:system-ui,sans-serif}.navbar__logo{display:flex;align-items:center;text-decoration:none}.navbar__logo img{display:block;height:26px}.navbar__collapse{display:flex;flex:1;align-items:center}.navbar__group{display:flex;align-items:center}.navbar__link{color:#cfd2d6;text-decoration:none;padding:0 14px;line-height:48px;font-size:14px}.navbar__link:hover{color:#fff}.navbar__link[data-active=true]{color:#fff;background:#ffffff14}.navbar__link--right{margin-left:auto}.navbar__toggle{display:none;width:40px;height:32px;background:transparent;border:1px solid rgba(255,255,255,.25);border-radius:4px;cursor:pointer}.navbar__toggle span{display:block;width:18px;height:2px;margin:3px auto;background:#cfd2d6}.navbar__mute{order:2;margin-left:auto;width:40px;height:32px;display:flex;align-items:center;justify-content:center;background:transparent;border:1px solid rgba(255,255,255,.25);border-radius:4px;cursor:pointer;font-size:16px;line-height:1}.page{box-sizing:border-box;width:100%;max-width:640px;padding:24px 24px 72px;text-align:center;color:#fff}.page__title{margin:0 0 16px;font-size:28px}.page p{margin:8px 0;line-height:1.6}.page__link{color:#4ec0ca}.page__fine{margin-top:24px;font-size:13px;opacity:.6}@font-face{font-family:Jersey10;src:url(/fonts/Jersey10-Regular.woff2) format(\"woff2\"),url(/fonts/Jersey10-Regular.ttf) format(\"truetype\");font-display:swap}.leaderboard-page{max-width:460px;padding-bottom:88px}.leaderboard-panel{box-sizing:border-box;padding:4px 26px 22px;background:url(/sprites/panel-outside.png);background-size:100% 100%;image-rendering:pixelated;font-family:Jersey10,sans-serif;color:#5a3a18}.leaderboard-panel__ribbon{box-sizing:border-box;width:92%;margin:0 auto 4px;padding:18px 0 40px;background:url(/sprites/leaderboard-ribbon.png);background-size:100% 100%;image-rendering:pixelated;display:flex;flex-direction:column;align-items:center;text-align:center}.leaderboard-tabs{display:flex;align-items:center;justify-content:center;gap:6px}.leaderboard-tab{width:134px;height:46px;padding:0;border:none;background:url(/sprites/tab-inactive.png) no-repeat center / 100% 100%;image-rendering:pixelated;cursor:pointer;font-family:Jersey10,sans-serif;font-size:22px;letter-spacing:1px;color:#fff;text-shadow:2px 2px 0 #5b1212}.leaderboard-tab[data-active]{background-image:url(/sprites/tab-active.png);color:#43290f;text-shadow:none}.leaderboard-countdown{margin:6px 0 16px;text-align:center;font-size:22px;letter-spacing:1px;color:#fff;text-shadow:2px 2px 0 #000,-2px -2px 0 #000,2px -2px 0 #000,-2px 2px 0 #000}.leaderboard-panel__notice{margin:56px 0 64px;text-align:center;font-size:26px;letter-spacing:1px;color:#b3835d}.leaderboard-panel__rows{margin:0;padding:0 6px 0 0;list-style:none;max-height:48vh;overflow-y:auto;overscroll-behavior:contain;scrollbar-width:thin;scrollbar-color:#b3835d rgba(90,58,24,.15)}.leaderboard-panel__rows::-webkit-scrollbar{width:9px}.leaderboard-panel__rows::-webkit-scrollbar-track{background:#5a3a181f;border-radius:5px}.leaderboard-panel__rows::-webkit-scrollbar-thumb{background:#b3835d;border-radius:5px;border:2px solid transparent;background-clip:padding-box}.leaderboard-row{display:flex;align-items:center;gap:10px;padding:5px 6px;font-size:22px}.leaderboard-row[data-you]{background:#3f81de4d;border-radius:6px}.leaderboard-row__rank{flex:0 0 34px;height:34px;line-height:34px;background:url(/sprites/rank-circle.png);background-size:100% 100%;image-rendering:pixelated;text-align:center}.leaderboard-row__rank--gold{color:#c79100}.leaderboard-row__rank--silver{color:#8c9095}.leaderboard-row__rank--bronze{color:#cd6a1f}.leaderboard-row__name{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-align:left}.leaderboard-row__score{flex:0 0 96px;padding:3px 0;background:url(/sprites/score-slot.png);background-size:100% 100%;image-rendering:pixelated;text-align:center;color:#f7e7cd}.leaderboard-you{display:flex;align-items:center;gap:10px;box-sizing:border-box;margin-top:14px;padding:10px 14px;background:url(/sprites/you-slot.png);background-size:100% 100%;image-rendering:pixelated;color:#fff;font-size:22px}.leaderboard-you__rank{flex:0 0 34px;height:34px;line-height:34px;border-radius:50%;background:#1d4f9e;text-align:center}.leaderboard-you__name{flex:1;text-align:left;letter-spacing:1px}.leaderboard-you__score{flex:0 0 31%;margin-right:4%;text-align:center}@media(max-width:640px){.navbar__toggle{display:block;order:1}.navbar__collapse{position:absolute;left:0;right:0;bottom:100%;flex-direction:column;align-items:stretch;background:#2c2f33;box-shadow:0 -1px 4px #0006;display:none}.navbar__collapse[data-open=true]{display:flex}.navbar__group{flex-direction:column;align-items:stretch}.navbar__link{line-height:44px;text-align:center;border-top:1px solid rgba(255,255,255,.06)}.navbar__link--right{margin-left:0}}.name-gate{position:fixed;inset:0;z-index:200;display:flex;align-items:center;justify-content:center;background:#0000008c}.name-gate__panel{position:relative;display:flex;flex-direction:column;gap:14px;box-sizing:border-box;width:min(86vw,360px);padding:26px 30px 30px;background:url(/sprites/panel-outside.png);background-size:100% 100%;image-rendering:pixelated;font-family:Jersey10,sans-serif;color:#5a3a18}.name-gate__close{position:absolute;top:8px;right:12px;display:flex;align-items:center;justify-content:center;width:34px;height:34px;padding:0;border:0;background:transparent;font-family:inherit;font-size:36px;line-height:1;color:#5a3a18;cursor:pointer}.name-gate__close:hover{color:#b3261e}.name-gate__title{margin:0;text-align:center;font-size:30px;font-weight:400;letter-spacing:1px}.name-gate__hint{margin:0;text-align:center;font-size:18px;color:#b3835d}.name-gate__input{box-sizing:border-box;width:100%;padding:8px 12px;border:2px solid #5a3a18;border-radius:6px;background:#f7e7cd;color:#5a3a18;font-family:inherit;font-size:22px}.name-gate__input::placeholder{color:#b3835d}.name-gate__error{margin:0;text-align:center;font-size:18px;color:#b3261e}.name-gate__actions{display:flex;justify-content:center;gap:12px}.name-gate__button{padding:10px 26px 12px;border:0;background:#5dc83d url(/sprites/button-start.png);background-size:100% 100%;background-blend-mode:multiply;-webkit-mask-image:url(/sprites/button-start.png);-webkit-mask-size:100% 100%;mask-image:url(/sprites/button-start.png);mask-size:100% 100%;image-rendering:pixelated;font-family:inherit;font-size:22px;letter-spacing:1px;text-transform:uppercase;color:#fff;text-shadow:-2px -2px 0 #000,2px -2px 0 #000,-2px 2px 0 #000,2px 2px 0 #000;cursor:pointer}\n"
          },
