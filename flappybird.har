            "text": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.svg\" />\n    <link rel=\"icon\" type=\"image/png\" sizes=\"96x96\" href=\"/favicon-96x96.png\" />\n    <link rel=\"icon\" href=\"/favicon.ico\" sizes=\"any\" />\n    <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\" />\n    <link rel=\"manifest\" href=\"/site.webmanifest\" />\n    <link rel=\"preconnect\" href=\"https://maincloud.spacetimedb.com\" crossorigin />\n    <link\n      rel=\"preload\"\n      href=\"/fonts/Jersey10-Regular.woff2\"\n      as=\"font\"\n      type=\"font/woff2\"\n      crossorigin\n    />\n    <title>Play Flappy Bird Online — Free, No Download</title>\n    <meta\n      name=\"description\"\n      content=\"Play Flappy Bird online for free — no download, no signup. Tap to flap, dodge the pipes, and climb the global daily and all-time leaderboards.\"\n    />\n    <link rel=\"canonical\" href=\"https://flappybird.io/\" />\n    <link rel=\"alternate\" hreflang=\"en\" href=\"https://flappybird.io/\" />\n    <link rel=\"alternate\" hreflang=\"pt\" href=\"https://flappybird.io/pt\" />\n    <link rel=\"alternate\" hreflang=\"es\" href=\"https://flappybird.io/es\" />\n    <link rel=\"alternate\" hreflang=\"tr\" href=\"https://flappybird.io/tr\" />\n    <link rel=\"alternate\" hreflang=\"vi\" href=\"https://flappybird.io/vi\" />\n    <link rel=\"alternate\" hreflang=\"x-default\" href=\"https://flappybird.io/\" />\n    <meta name=\"theme-color\" content=\"#4ec0ca\" />\n    <meta property=\"og:locale\" content=\"en_US\" />\n    <meta property=\"og:type\" content=\"website\" />\n    <meta property=\"og:site_name\" content=\"flappybird.io\" />\n    <meta property=\"og:title\" content=\"Play Flappy Bird Online — Free, No Download\" />\n    <meta\n      property=\"og:description\"\n      content=\"Play Flappy Bird online for free — no download, no signup. Tap to flap and climb the global leaderboards.\"\n    />\n    <meta property=\"og:url\" content=\"https://flappybird.io/\" />\n    <meta property=\"og:image\" content=\"https://flappybird.io/og-image.png\" />\n    <meta property=\"og:image:width\" content=\"1200\" />\n    <meta property=\"og:image:height\" content=\"630\" />\n    <meta property=\"og:image:alt\" content=\"Flappy Bird flying between green pipes\" />\n    <meta name=\"twitter:card\" content=\"summary_large_image\" />\n    <meta name=\"twitter:title\" content=\"Play Flappy Bird Online — Free, No Download\" />\n    <meta\n      name=\"twitter:description\"\n      content=\"Play Flappy Bird online for free — no download, no signup. Tap to flap and climb the global leaderboards.\"\n    />\n    <meta name=\"twitter:image\" content=\"https://flappybird.io/og-image.png\" />\n    <script type=\"application/ld+json\">\n      {\n        \"@context\": \"https://schema.org\",\n        \"@graph\": [\n          {\n            \"@type\": \"VideoGame\",\n            \"name\": \"Flappy Bird\",\n            \"url\": \"https://flappybird.io/\",\n            \"image\": \"https://flappybird.io/og-image.png\",\n            \"genre\": \"Arcade\",\n            \"playMode\": \"SinglePlayer\",\n            \"applicationCategory\": \"Game\",\n            \"operatingSystem\": \"Web browser\",\n            \"offers\": { \"@type\": \"Offer\", \"price\": \"0\", \"priceCurrency\": \"USD\" }\n          },\n          {\n            \"@type\": \"WebSite\",\n            \"name\": \"flappybird.io\",\n            \"url\": \"https://flappybird.io/\"\n          }\n        ]\n      }\n    </script>\n    <meta name=\"google\" content=\"notranslate\" />\n    <style>\n      .boot-splash {\n        position: fixed;\n        inset: 0;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        gap: 16px;\n        background: #4ec0ca;\n        color: #fff;\n        z-index: 200;\n        font-family: system-ui, sans-serif;\n      }\n      .boot-splash__logo {\n        width: min(78vw, 460px);\n        height: auto;\n      }\n      .boot-splash__spinner {\n        margin-top: 12vh;\n        width: 48px;\n        height: 48px;\n        border: 5px solid rgba(255, 255, 255, 0.4);\n        border-top-color: #fff;\n        border-radius: 50%;\n        animation: boot-spin 0.8s linear infinite;\n      }\n      .boot-splash__label {\n        font-size: 18px;\n        letter-spacing: 0.05em;\n      }\n      @keyframes boot-spin {\n        to {\n          transform: rotate(360deg);\n        }\n      }\n    </style>\n    <script type=\"module\" crossorigin src=\"/assets/index-buPetfY7.js\"></script>\n    <link rel=\"stylesheet\" crossorigin href=\"/assets/index-Bs6ujsKE.css\">\n  </head>\n  <body>\n    <div id=\"root\">\n      <div class=\"boot-splash\">\n        <img class=\"boot-splash__logo\" src=\"/sprites/logo.webp\" alt=\"Flappy Bird\" />\n        <div class=\"boot-splash__spinner\"></div>\n        <div class=\"boot-splash__label\">Loading…</div>\n      </div>\n    </div>\n  </body>\n</html>\n"
