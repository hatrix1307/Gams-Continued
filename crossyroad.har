            "size": 6475,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\r\n<html lang=\"en-us\">\r\n\r\n<head>\r\n  <title>Crossy Road</title>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\r\n  <meta name=\"robots\" content=\"noindex, nofollow\">\r\n  <link rel=\"canonical\" href=\"/game/crossy-road/\">\r\n  <meta name=\"title\" content=\"Crossy Road Online!\">\r\n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\r\n  <link rel=\"shortcut icon\" href=\"favicon.png\">\r\n  <link rel=\"stylesheet\" href=\"TemplateData/style.css\">\r\n  <style>\r\n    @font-face {\r\n      font-family: BRLNSDB;\r\n      src: url('BRLNSDB.TTF');\r\n    }\r\n\r\n    .font1 {\r\n      font-family: BRLNSDB;\r\n      position: absolute;\r\n      left: -10000px;\r\n      visibility: hidden;\r\n    }\r\n  </style>\r\n</head>\r\n\r\n<body class=\"dark\">\r\n  <div class=\"font1\">.</div>\r\n  <div id=\"unity-container\" class=\"unity-desktop\">\r\n    <canvas id=\"unity-canvas\"></canvas>\r\n  </div>\r\n  <div id=\"loading-cover\" style=\"display:none;\">\r\n    <div id=\"unity-loading-bar\">\r\n      <div style=\"position: absolute; bottom: 10px; right: 10px; font-size: 18px; color: #000; opacity: 0.5;\">crossy-road</div>\r\n      <img src=\"loading.png?v=1\" id=\"ld_bg\" style=\"width: 100%; height: 100%; object-fit: cover;\">\r\n      <canvas id=\"logo-canvas\" style=\"position: absolute; background-color: transparent;\">\r\n        <img src=\"loading_fill.png\" id=\"ld_fill\">\r\n        <img src=\"loading_bar.png\" id=\"ld_bar\">\r\n        <img src=\"logo.png\" id=\"logo\">\r\n      </canvas>\r\n    </div>\r\n  </div>\r\n  <script>\r\n    const container = document.querySelector(\"#unity-container\");\r\n    const canvas = document.querySelector(\"#unity-canvas\");\r\n    const loadingCover = document.querySelector(\"#loading-cover\");\r\n    const fullscreenButton = document.querySelector(\"#unity-fullscreen-button\");\r\n    const buildUrl = \"Build\";\r\n    const loaderUrl = buildUrl + \"/crossy-road.loader.js\";\r\n    const config = {\r\n      dataUrl: buildUrl + \"/crossy-road.data.unityweb\",\r\n      frameworkUrl: buildUrl + \"/crossy-road.framework.js.unityweb\",\r\n      codeUrl: buildUrl + \"/crossy-road.wasm.unityweb\",\r\n      streamingAssetsUrl: \"StreamingAssets\",\r\n      companyName: \"ozgames.io\",\r\n      productName: \"Crossy Road\",\r\n      productVersion: \"1.0\",\r\n    };\r\n\r\n    if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent)) {\r\n      container.className = \"unity-mobile\";\r\n      config.devicePixelRatio = 1;\r\n    }\r\n\r\n    function delay(ms) {\r\n      return new Promise((resolve, reject) => {\r\n        setTimeout(() => {\r\n          resolve();\r\n        }, ms);\r\n      });\r\n    }\r\n\r\n    async function load() {\r\n      logo_loaded = false;\r\n      createUnityInstance(canvas, config, (progress) => {\r\n        logo_loading_percent = progress;\r\n        drawCanvas(progress);\r\n      }).then((unityInstance) => {\r\n        window.unityInstance = unityInstance;\r\n        setTimeout(() => {\r\n          loadingCover.style.display = \"none\";\r\n          logo_loaded = true;\r\n        }, 2000);\r\n      }).catch((message) => {\r\n        alert(message);\r\n      });\r\n    }\r\n\r\n    loadingCover.style.display = \"\";\r\n    var script = document.createElement(\"script\");\r\n    script.src = loaderUrl;\r\n    script.onload = () => {\r\n      load();\r\n    };\r\n    var logo_loaded = false;\r\n    var logo_loading_percent = 0;\r\n\r\n    window.onresize = () => {\r\n      drawCanvas(logo_loading_percent);\r\n    }\r\n    window.onload = () => {\r\n      drawCanvas(logo_loading_percent);\r\n    }\r\n\r\n    var logo_canvas = document.getElementById(\"logo-canvas\");\r\n\r\n    function drawCanvas(_percent = 0) {\r\n      if (logo_loaded) {\r\n        return;\r\n      }\r\n      resizeLogoCanvas();\r\n      var ctx = logo_canvas.getContext(\"2d\");\r\n      var logo = document.getElementById(\"logo\");\r\n      var ld_fill = document.getElementById(\"ld_fill\");\r\n      var ld_bar = document.getElementById(\"ld_bar\");\r\n      var _sw = logo_canvas.width / 1920;\r\n      var _sh = logo_canvas.height / 1080;\r\n\r\n      if (_percent > 1) {\r\n        _percent = 1;\r\n      }\r\n\r\n      var pl = 890 * _percent;\r\n      var pw = 900 - pl;\r\n      pl = pl + 510;\r\n      ctx.drawImage(logo, 622.5 * _sw, 77 * _sh, 675 * _sw, 396 * _sh);\r\n      ctx.drawImage(ld_bar, 510 * _sw, logo_canvas.height - (115.5 * _sh), 900 * _sw, 44 * _sh);\r\n      ctx.drawImage(ld_fill, pl * _sw, logo_canvas.height - (111 * _sh), pw * _sw, 35 * _sh);\r\n\r\n      var _fontSize = 32 * _sw;\r\n      ctx.font = _fontSize.toString() + \"px BRLNSDB\";\r\n      ctx.fillStyle = \"#ffffff\";\r\n      ctx.textAligh = \"center\";\r\n      ctx.lineWidth = 5 * _sw;\r\n      ctx.strokeStyle = '#000000';\r\n      let _txt = (Math.floor(_percent * 100)).toString() + '%';\r\n      let _tx = logo_canvas.width * 0.5 - ctx.measureText(_txt).width * 0.5 * _sw - 20 * _sw;\r\n      let _ty = logo_canvas.height * 0.5 + 455 * _sh;\r\n      ctx.strokeText(_txt, _tx, _ty);\r\n      ctx.fillText(_txt, _tx, _ty);\r\n    }\r\n\r\n    function resizeLogoCanvas() {\r\n      var _w = window.innerWidth;\r\n      var _h = window.innerHeight;\r\n      var _nw = _h * 16 / 9;\r\n      if (_nw <= _w) {\r\n        logo_canvas.width = _nw;\r\n        logo_canvas.height = _h;\r\n      } else {\r\n        logo_canvas.width = _w;\r\n        logo_canvas.height = _w * 9 / 16;\r\n      }\r\n    }\r\n\r\n    document.body.appendChild(script);\r\n  </script>\r\n  <script>\r\n    function createSuperProxy() {\r\n      const handler = {\r\n        get(target, prop) {\r\n          if (prop === 'then') return (cb) => {\r\n            cb && cb(superProxy);\r\n            return superProxy;\r\n          };\r\n          if (prop === 'catch') return () => superProxy;\r\n          if (prop === 'finally') return () => superProxy;\r\n          return superProxy;\r\n        },\r\n        apply() {\r\n          return superProxy;\r\n        }\r\n      };\r\n\r\n      function dummy() {\r\n        return dummy;\r\n      }\r\n      const superProxy = new Proxy(dummy, handler);\r\n      return superProxy;\r\n    }\r\n    window.firebase = createSuperProxy();\r\n    window.gtag = function() {};\r\n  </script>\r\n\r\n<script defer src=\"https://static.cloudflareinsights.com/beacon.min.js/v4513226cdae34746b4dedf0b4dfa099e1781791509496\" integrity=\"sha512-ZE9pZaUXND66v380QUtch/5sE9tPFh2zg45pR2PB0CVkCtOREv2AJKkSidISWkysEuQ0EH8faUU5du78bx87UQ==\" data-cf-beacon='{\"version\":\"2024.11.0\",\"token\":\"4f79a35af6534f0f9d4321bd17960804\",\"r\":1,\"server_timing\":{\"name\":{\"cfCacheStatus\":true,\"cfEdge\":true,\"cfExtPri\":true,\"cfL4\":true,\"cfOrigin\":true,\"cfSpeedBrain\":true},\"location_startswith\":null}}' crossorigin=\"anonymous\"></script>\n</body>\r\n\r\n</html>"
